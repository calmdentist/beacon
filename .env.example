# Shared
NODE_ENV=development

# Web app
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beacon
NEON_AUTH_BASE_URL=https://replace-me.neon.tech
NEON_AUTH_COOKIE_SECRET=replace-me-with-a-32-char-cookie-secret
NEON_AUTH_SESSION_DATA_TTL=300
NEON_AUTH_COOKIE_DOMAIN=

# AI
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# MCP service
MCP_PORT=4000
MCP_PUBLIC_BASE_URL=http://localhost:4000
BEACON_API_URL=http://localhost:3000
BEACON_API_TOKEN=replace-me
MCP_AUTH_MODE=none
MCP_DEV_USER_ID=local-dev-user
MCP_REQUIRED_SCOPES=mcp:tools
MCP_USER_ID_CLAIM=sub
MCP_ALLOWED_HOSTS=localhost,127.0.0.1

# MCP OAuth mode only
MCP_OAUTH_ISSUER_URL=
MCP_OAUTH_AUTHORIZATION_ENDPOINT=
MCP_OAUTH_TOKEN_ENDPOINT=
MCP_OAUTH_REGISTRATION_ENDPOINT=
MCP_OAUTH_REVOCATION_ENDPOINT=
MCP_OAUTH_INTROSPECTION_ENDPOINT=
MCP_OAUTH_JWKS_URL=
MCP_OAUTH_AUDIENCE=
MCP_OAUTH_SCOPES_SUPPORTED=mcp:tools
