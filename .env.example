# Shared
NODE_ENV=development

# Web app
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beacon
NEON_AUTH_BASE_URL=https://replace-me.neon.tech
NEON_AUTH_COOKIE_SECRET=replace-me-with-a-32-char-cookie-secret
NEON_AUTH_SESSION_DATA_TTL=300
NEON_AUTH_COOKIE_DOMAIN=

# AI
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# MCP service
MCP_PORT=4000
MCP_PUBLIC_BASE_URL=http://localhost:4000
BEACON_API_URL=http://localhost:3000
BEACON_API_TOKEN=replace-me
MCP_AUTH_MODE=none
MCP_DEV_USER_ID=local-dev-user
MCP_REQUIRED_SCOPES=mcp:tools
MCP_ALLOWED_HOSTS=localhost,127.0.0.1

# MCP OAuth mode only (required when MCP_AUTH_MODE=oauth)
MCP_OAUTH_BRIDGE_SHARED_SECRET=replace-me-with-at-least-32-chars
MCP_OAUTH_SESSION_SECRET=replace-me-with-at-least-32-chars
MCP_OAUTH_TOKEN_SECRET=replace-me-with-at-least-32-chars

# MCP OAuth mode optional overrides
MCP_OAUTH_ISSUER_URL=
MCP_OAUTH_BRIDGE_URL=
MCP_OAUTH_SCOPES_SUPPORTED=mcp:tools
MCP_OAUTH_ENABLE_DCR=true
MCP_OAUTH_RESOURCE_NAME=Vibecast MCP
MCP_OAUTH_COOKIE_DOMAIN=
MCP_OAUTH_COOKIE_SECURE=
MCP_OAUTH_COOKIE_NAME=vibecast-mcp-session
MCP_OAUTH_SESSION_TTL_SECONDS=36000
MCP_OAUTH_AUTH_CODE_TTL_SECONDS=300
MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
MCP_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
