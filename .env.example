# Shared
NODE_ENV=development

# Web app
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beacon
AUTH_SECRET=replace-me
AUTH_GOOGLE_ID=
