{
  "name": "beacon",
  "private": true,
  "version": "0.1.0",
  "description": "Beacon monorepo foundation",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @beacon/web",
    "dev:mcp": "npm run dev -w @beacon/mcp",
    "dev": "npm run dev:web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate -w @beacon/db",
    "env:check:prod": "node scripts/check-production-env.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.0"
}
